{
  "name": "moribashi-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --filter './packages/**' run build",
    "clean": "pnpm -r run clean",
    "check": "biome check",
    "check:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "ci:check": "biome ci",
    "typecheck": "pnpm -r --workspace-concurrency=1 --filter='./packages/**' --filter='./examples/**' exec tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
